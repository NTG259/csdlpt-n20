@baseUrl = http://localhost:8080

### Register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "hoTen": "Nguyen Van A",
  "email": "nguyenvana@example.com",
  "soDienThoai": "0123456789",
  "matKhau": "matkhau123",
  "maKhuVuc": "KV01",
  "diaChi": "123 Duong Demo, Ha Noi",
  "ngaySinh": "2000-01-01",
  "gioiTinh": "Nam",
  "cccd": "123456789012"
}

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "nguyenvana@example.com",
  "matKhau": "matkhau123"
}

### Check Email
GET {{baseUrl}}/api/auth/check-email?email=nguyenvana@example.com

### Check Phone
GET {{baseUrl}}/api/auth/check-phone?phone=0123456789

### Products
GET {{baseUrl}}/api/products?page=0&size=10&sort=ngayTao,desc

### Products With Filters
GET {{baseUrl}}/api/products?page=0&size=5&sort=tenSP,asc&maDanhMuc=DM01&maThuongHieu=TH01&trangThai=true

### Product Detail
GET {{baseUrl}}/api/products/SP01

### Categories
GET {{baseUrl}}/api/categories

### Brands
GET {{baseUrl}}/api/brands

### Regions
GET {{baseUrl}}/api/regions
