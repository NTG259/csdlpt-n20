SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# SQL Server qua localhost, LAN, hoac Tailscale.
DB_URL=jdbc:sqlserver://100.x.x.x:1433;databaseName=store_management;encrypt=true;trustServerCertificate=true
DB_USERNAME=sa
DB_PASSWORD=change-me

# Phai giong nhau giua Site Main va cac site chi nhanh neu dung chung token.
JWT_SECRET=change-this-secret-key-to-at-least-32-characters
JWT_EXPIRATION_MS=31536000000

# Dev/Docker/Tailscale co the de *. Production nen thay bang origin FE cu the.
CORS_ALLOWED_ORIGIN_PATTERNS=*
